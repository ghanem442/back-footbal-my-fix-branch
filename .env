# ============================================
# APPLICATION CONFIGURATION
# ============================================
NODE_ENV=development
PORT=3000
APP_NAME="Football Field Booking API"
# Used for easier documentation (disabled on production)
ENABLE_SWAGGER=true

# ============================================
# DATABASE CONFIGURATION
# ============================================
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/football_booking?schema=public"

# For testing (use different database)
# DATABASE_URL="postgresql://test:test@localhost:5433/football_booking_test?schema=public"

# ============================================
# REDIS CONFIGURATION
# ============================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_CACHE_DB=0
REDIS_THROTTLE_DB=1
REDIS_QUEUE_DB=2

# For testing (use different port)
# REDIS_PORT=6380

# ============================================
# JWT AUTHENTICATION
# ============================================
JWT_SECRET=your-secret-key-change-in-production
JWT_REFRESH_SECRET=your-refresh-secret-key-change-in-production
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# ============================================
# OAUTH - GOOGLE
# ============================================
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:3000/api/v1/auth/google/callback

# ============================================
# OAUTH - FACEBOOK
# ============================================
FACEBOOK_APP_ID=your-facebook-app-id
FACEBOOK_APP_SECRET=your-facebook-app-secret
FACEBOOK_CALLBACK_URL=http://localhost:3000/api/v1/auth/facebook/callback

# ============================================
# PAYMENT GATEWAYS
# ============================================

# Stripe (International Payment Gateway)
STRIPE_SECRET_KEY=your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=your-stripe-webhook-secret

# Paymob (Egyptian Payment Gateway - Primary)
PAYMOB_API_KEY=ZXlKaGJHY2lPaUpJVXpVeE1pSXNJblI1Y0NJNklrcFhWQ0o5LmV5SmpiR0Z6Y3lJNklrMWxjbU5vWVc1MElpd2ljSEp2Wm1sc1pWOXdheUk2TVRFME5qRTBOU3dpYm1GdFpTSTZJbWx1YVhScFlXd2lmUS55VEMyMXZJYTMxajR1WVN6NWszd0JleUZCdFlNd1dsMmc5ZktoT1VjU1U0cWFGcGZJbXZMbVNfOHhrbl8wZjRaYW9kaE1ydXp5aUs1bHVPbEhVWHJ4Zw==
PAYMOB_INTEGRATION_ID=5592196
PAYMOB_IFRAME_ID=1022725
PAYMOB_HMAC_SECRET=

# Fawry (Egyptian Payment Gateway - Optional)
FAWRY_MERCHANT_CODE=your-fawry-merchant-code
FAWRY_SECRET_KEY=your-fawry-secret-key

# Vodafone Cash (Egyptian Mobile Payment - Manual Verification)
VODAFONE_MERCHANT_ID=your-vodafone-merchant-id
VODAFONE_SECRET_KEY=your-vodafone-secret-key

# InstaPay (Egyptian Instant Payment - Manual Verification)
INSTAPAY_MERCHANT_ID=your-instapay-merchant-id
INSTAPAY_SECRET_KEY=your-instapay-secret-key

# Ngrok URL (for local development webhook testing)
NGROK_URL=https://ferne-nonpresentable-unprepossessingly.ngrok-free.dev

# ============================================
# SMS - TWILIO
# ============================================
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=your-twilio-phone-number

# ============================================
# EMAIL - SENDGRID
# ============================================
SENDGRID_API_KEY=your-sendgrid-api-key
SENDGRID_FROM_EMAIL=noreply@yourdomain.com
SENDGRID_FROM_NAME="Football Booking"

# ============================================
# EMAIL - SMTP (Gmail Alternative)
# ============================================
# To use Gmail:
# 1. Go to https://myaccount.google.com/apppasswords
# 2. Generate an "App Password" (not your regular Gmail password)
# 3. Use that password below
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=my01281105973@gmail.com
SMTP_PASS=your-gmail-app-password-here
SMTP_FROM_EMAIL=my01281105973@gmail.com
SMTP_FROM_NAME="Football Booking"

# ============================================
# FRONTEND URL (for email links)
# ============================================
FRONTEND_URL=http://localhost:3000

# ============================================
# FIREBASE CLOUD MESSAGING (PUSH NOTIFICATIONS)
# ============================================
# Paste the entire Firebase service account JSON as a single line string
FIREBASE_SERVICE_ACCOUNT='{"type":"service_account","project_id":"your-project-id","private_key_id":"your-key-id","private_key":"-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY\n-----END PRIVATE KEY-----\n","client_email":"firebase-adminsdk@your-project.iam.gserviceaccount.com","client_id":"your-client-id","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token","auth_provider_x509_cert_url":"https://www.googleapis.com/oauth2/v1/certs","client_x509_cert_url":"your-cert-url"}'

# ============================================
# FILE STORAGE
# ============================================
STORAGE_PROVIDER=local # Options: local, s3, cloudinary, hostinger

# Local Storage (Development)
STORAGE_LOCAL_PATH=./uploads
STORAGE_LOCAL_BASE_URL=http://192.168.1.218:3000/uploads

# AWS S3 Storage (Production)
AWS_S3_BUCKET=your-s3-bucket
AWS_S3_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key

# Cloudinary Storage (Alternative)
CLOUDINARY_CLOUD_NAME=your-cloudinary-cloud-name
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret

# Hostinger Object Storage (Alternative - S3 Compatible)
HOSTINGER_ENDPOINT=https://your-region.hostinger.com
HOSTINGER_BUCKET=your-hostinger-bucket
HOSTINGER_ACCESS_KEY=your-hostinger-access-key
HOSTINGER_SECRET_KEY=your-hostinger-secret-key
HOSTINGER_REGION=your-region
HOSTINGER_PUBLIC_URL=https://your-bucket.your-region.hostinger.com

# ============================================
# SYSTEM CONFIGURATION
# ============================================
# Deposit percentage: Percentage of total booking price paid online (default 20%)
# The remaining amount (80%) is paid in cash at the field
DEPOSIT_PERCENTAGE=20

# Platform commission: Percentage of the DEPOSIT that goes to the platform (default 50%)
# This means if deposit is 20% of total, platform gets 10% of total (50% of 20%)
# Field owner gets the other 50% of deposit in their wallet (10% of total)
# Field owner also receives the remaining 80% in cash at the field
GLOBAL_COMMISSION_RATE=50

BOOKING_TIMEOUT_MINUTES=15
NO_SHOW_THRESHOLD_MINUTES=30
NO_SHOW_THRESHOLD=3
SUSPENSION_DAYS=30
REMINDER_HOURS_BEFORE=2

# ============================================
# CORS CONFIGURATION
# ============================================
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# For production, use your actual domains:
# CORS_ORIGINS=https://yourdomain.com,https://app.yourdomain.com

# ============================================
# RATE LIMITING
# ============================================
RATE_LIMIT_TTL=900000
RATE_LIMIT_MAX=100
AUTH_RATE_LIMIT_TTL=900000
AUTH_RATE_LIMIT_MAX=5

# ============================================
# LOGGING
# ============================================
LOG_LEVEL=info # Options: debug, info, warn, error
LOG_FORMAT=json # Options: json, simple

# ============================================
# API DOCUMENTATION
# ============================================
# Set to false to disable Swagger in production
ENABLE_SWAGGER=true

# ============================================
# MONITORING & ERROR TRACKING (OPTIONAL)
# ============================================
# Sentry DSN for error tracking
# SENTRY_DSN=https://...@sentry.io/...

# ============================================
# TESTING CONFIGURATION
# ============================================
# Uncomment these when running tests
# DEBUG_TESTS=false
# TEST_TIMEOUT=10000

# ============================================
# NOTES
# ============================================
# For Testing:
#   - Use different DATABASE_URL with test database
#   - Use different REDIS_PORT (e.g., 6380)
#   - Set NODE_ENV=test
#   - Use mock values for external services
#
# For Production:
#   - Set NODE_ENV=production
#   - Use strong JWT secrets (min 32 characters)
#   - Enable HTTPS for all callback URLs
#   - Use production credentials for all services
#   - Set STORAGE_PROVIDER=s3 or cloudinary
#   - Configure proper CORS_ORIGINS
#   - Disable SWAGGER_ENABLED or protect with auth
#   - Enable SENTRY_DSN for error tracking
